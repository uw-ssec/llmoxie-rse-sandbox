{
  "name": "LLMaven RSE Sandbox",
  "image": "ghcr.io/uw-ssec/llmaven-rse-sandbox-devcontainer@sha256:8ed8e1e6fe3e77515e728daea81897898513d9a7c602033f7c40125ad3371fb0",
  // Node provides the `npx` that install-skills.sh uses to install the
  // ai-research-workflows skills into Copilot. The pinned base image ships no
  // Node, so add it as a create-time feature (applied before the lifecycle
  // scripts run) rather than relying on the image.
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "marp-team.marp-vscode"
      ],
      "settings": {
        "chat.plugins.enabled": false,
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.pixi/envs/default/bin/python",
        "python.useEnvironmentsExtension": false,
        "oaicopilot.baseUrl": "${localEnv:LITELLM_BASE_URL}/v1",
        "oaicopilot.models": [
          {
              "id": "gpt-5.4-mini",
              "displayName": "GPT 5.4 Mini (UW SSEC)",
              "owned_by": "uw-ssec",
              "temperature": 1,
              "isUserSelectable": true,
              "isDefault": true,
              "extra": {
                  "allowed_openai_params": ["top_p"]
              }
          },
          {
              "id": "gpt-oss-120b",
              "displayName": "GPT OSS 120B (UW SSEC)",
              "owned_by": "uw-ssec",
              "isUserSelectable": true
          }
      ],
        // "readme" opens the README as a rendered preview during first-launch
        // setup — the only startup surface Codespaces reliably renders. Its
        // top callout carries the "setup in progress" instructions; the
        // walkthrough takes over on the next window load.
        "workbench.startupEditor": "readme",
        "markdown.marp.themes": ["./docs/slides/themes/sandbox.css"],
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/.git/subtree-cache/**": true,
          "**/node_modules/**": true,
          "**/.pixi/**": true
        }
      }
    }
  },
  "secrets": {
    "LITELLM_BASE_URL": {
      "description": "Base URL for the LLMaven / LiteLLM gateway"
    },
    "LITELLM_API_KEY": {
      "description": "API key for the LLMaven / LiteLLM gateway"
    }
  },
  "mounts": [
    "source=${localWorkspaceFolderBasename}-pixi,target=${containerWorkspaceFolder}/.pixi,type=volume"
  ],
  "remoteEnv": {
    // OAI_API_KEY is placed in remoteEnv because the LLMaven Copilot extension runtime reads
    // that OpenAI-compatible environment variable at activation time. Setting it only around
    // lifecycle shell commands would not propagate to the VS Code extension host.
    "OAI_API_KEY": "${localEnv:LITELLM_API_KEY}",
    // Point the GitHub Copilot CLI (BYOK) at the same LLMaven gateway used by the
    // oaicopilot extension so the CLI exposes the same models. Users can switch
    // among the available models in-session via the /model slash command
    // (e.g. /model gpt-5.4-mini, /model gpt-5.4-pro, /model gpt-oss-120b).
    "COPILOT_PROVIDER_BASE_URL": "${localEnv:LITELLM_BASE_URL}/v1",
    "COPILOT_PROVIDER_API_KEY": "${localEnv:LITELLM_API_KEY}",
    "COPILOT_MODEL": "gpt-5.3-codex",
    "COPILOT_PROVIDER_WIRE_API": "responses"
  },
  "onCreateCommand": "bash .devcontainer/on-create.sh",
  // Keep the Codespaces "Setting up" screen until post-create finishes, so
  // users land in a fully provisioned editor instead of watching setup output.
  "waitFor": "postCreateCommand",
  // `pixi install --locked` is repeated here as a prebuild safety net: the
  // .pixi volume is not captured in prebuild snapshots and onCreateCommand
  // does not re-run for Codespaces created from a prebuild, so without this
  // the pixi env would be empty there. When on-create already installed it,
  // this is a fast no-op.
  "postCreateCommand": "pixi install --locked && bash .devcontainer/post-create.sh && bash .devcontainer/install-skills.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "postAttachCommand": "bash .devcontainer/install-vsix.sh && bash .devcontainer/install-walkthrough.sh",
  "remoteUser": "vscode"
}
