# OAI-compatible Copilot VSIX release pin.
#
# This file is the reviewed trust anchor for the VSIX consumed by the sandbox.
# Update these values only through reviewed PRs.
#
# This file is parsed as data by the lifecycle scripts. It is not sourced as shell.

# Current release tag. Prefer a versioned immutable tag when available.
# If using sandbox-latest, safety comes from EXPECTED_VSIX_SHA256 below,
# not from the tag name itself.
VSIX_RELEASE_TAG=sandbox-latest

VSIX_FILENAME=oai-compatible-copilot-sandbox.vsix

# Optional human-readable metadata for reviewers.
# This is not used for cryptographic verification.
VSIX_SOURCE_COMMIT=cfefa21

# Expected SHA256 of the reviewed VSIX artifact.
#
# Generate with:
#   sha256sum oai-compatible-copilot-sandbox.vsix
#
# Important: this value must be committed in-repo, not downloaded from GitHub
# next to the artifact. Otherwise artifact + checksum can be replaced together.
EXPECTED_VSIX_SHA256=321d49880133c241ff73bc2ce724a13c59c34c9fbbce6b15d29115196d55af22
